---
interface Props {
  title: string;
  hook?: string;
}

const { title, hook } = Astro.props;
---

<style is:global>
  .explainer-page-nav,
  .explainer-page-intro {
    width: min(1160px, calc(100% - 30px));
    margin-inline: auto;
    font-family: Inter, Roboto, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .explainer-page-nav {
    position: relative;
    display: flex;
    align-items: center;
    padding-top: 18px;
  }

  .explainer-page-home {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    min-height: 42px;
    padding: 8px 12px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 14px;
    background: rgba(24, 22, 31, 0.78);
    color: rgba(255, 255, 255, 0.94);
    text-decoration: none;
    font-size: 0.86rem;
    font-weight: 800;
  }

  .explainer-page-home img {
    width: 25px;
    height: 25px;
    border-radius: 7px;
  }

  .explainer-page-home:hover {
    border-color: rgba(196, 181, 253, 0.68);
    background: rgba(36, 32, 46, 0.9);
  }

  .explainer-page-home:focus-visible {
    outline: 3px solid rgba(196, 181, 253, 0.72);
    outline-offset: 3px;
  }

  .explainer-page-intro {
    padding: clamp(42px, 7vw, 82px) 4px clamp(22px, 4vw, 42px);
    color: rgba(255, 255, 255, 0.94);
  }

  .explainer-page-intro__eyebrow {
    color: #c4b5fd;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .explainer-page-intro h1 {
    max-width: 1040px;
    margin: 14px 0 0;
    font-size: clamp(3rem, 8vw, 6.8rem);
    line-height: 0.96;
    letter-spacing: -0.055em;
  }

  .explainer-page-intro__hook {
    max-width: 820px;
    margin: 20px 0 0;
    color: rgba(255, 255, 255, 0.66);
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    line-height: 1.65;
  }

  body.explainer-page-with-intro astro-island h1:first-of-type {
    display: none !important;
  }

  @media (max-width: 560px) {
    .explainer-page-nav,
    .explainer-page-intro {
      width: calc(100% - 20px);
    }
  }
</style>

<nav class="explainer-page-nav" aria-label="Explainer navigation">
  <a class="explainer-page-home" href="/" aria-label="Return to the Uppercut Labs Explainers home page">
    <img src="/icons/favicon-32x32.png" width="25" height="25" alt="" aria-hidden="true" />
    <span>Explainers</span>
  </a>
</nav>

<header class="explainer-page-intro">
  <div class="explainer-page-intro__eyebrow">Uppercut Labs Explainer</div>
  <h1>{title}</h1>
  {hook && <p class="explainer-page-intro__hook">{hook}</p>}
</header>
