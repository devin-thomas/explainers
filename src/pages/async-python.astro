---
import AsyncPythonExplainer from "../components/AsyncPythonExplainer";
import ExplainerPageIntro from "../components/ExplainerPageIntro.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#141218" />
    <meta
      name="description"
      content="A beginner-focused interactive mental model for asynchronous Python, event loops, tasks, awaits, and non-blocking work."
    />
    <title>Async in Python — Explainers</title>
    <meta property="og:title" content="Async in Python" />
    <meta name="application-name" content="Uppercut Labs Explainers" />
    <meta name="apple-mobile-web-app-title" content="Explainers" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="mobile-web-app-capable" content="yes" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="icon" href="/icons/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <script is:inline src="/pwa.js" defer></script>
    <style>html, body { min-height: 100%; margin: 0; background: #141218; }</style>
  </head>
  <body class="explainer-page-with-intro">
    <ExplainerPageIntro
      title="Async in Python"
      hook="Async is smart waiting: let one task pause while another useful task moves forward."
    />
    <AsyncPythonExplainer client:load />
  </body>
</html>
