---
const approaches = [
  {
    n: "01", group: "native", accent: "#82d5c3", kind: "Direct upload", title: "One index.html", file: "index.html",
    summary: "A complete document with inline CSS and JavaScript. This is the smallest genuinely self-contained website.",
    use: "One-off explainers, prototypes, portfolios, event pages, tiny tools, and artifacts that should remain portable.",
    tree: "site/\n└── index.html",
    requirements: ["A complete HTML document with doctype, language, head, viewport, title, and body.", "CSS in a <style> element and JavaScript in a <script> element.", "A static host—or a simple local HTTP server for reliable previewing."],
    pros: ["No packages, build, or generated output.", "Upload one file almost anywhere.", "Easy to archive, inspect, and move."],
    cons: ["Gets unwieldy as code grows.", "Weak reuse across pages.", "One large file is harder to maintain."],
    browser: "Yes", build: "None", publish: "The file itself"
  },
  {
    n: "02", group: "native", accent: "#9bc7ff", kind: "Direct upload", title: "HTML + CSS + JavaScript", file: "index.html + styles.css + script.js",
    summary: "The classic browser-native split: structure, presentation, and behavior remain separate without adding a toolchain.",
    use: "Small sites that have outgrown one file but do not need packages, compilation, or component frameworks.",
    tree: "site/\n├── index.html\n├── styles.css\n└── script.js",
    requirements: ["A stylesheet link in the document head.", "A deferred script, or type=module when using imports.", "Relative paths that remain intact after upload."],
    pros: ["Readable separation with zero build overhead.", "CSS and JS cache independently.", "Easy path toward modules later."],
    cons: ["No type checking.", "Manual DOM state can become complex.", "Global CSS and state need discipline."],
    browser: "Yes", build: "None", publish: "The folder"
  },
  {
    n: "03", group: "native", accent: "#f2b8d2", kind: "Direct upload", title: "HTML + native JS modules", file: "index.html + main.js + modules",
    summary: "Use type=module plus import/export to split behavior into browser-native modules without bundling.",
    use: "Small-to-medium tools that benefit from modules but do not need npm packages bundled for the browser.",
    tree: "site/\n├── index.html\n├── styles.css\n└── js/\n    ├── main.js\n    ├── ui.js\n    └── data.js",
    requirements: ["The entry script uses type=module.", "Imports use browser-resolvable URLs such as ./ui.js.", "A local HTTP server is recommended; file:// has security limitations."],
    pros: ["Native modules and scoped files.", "No bundler lock-in.", "Transparent network behavior."],
    cons: ["Bare npm package imports are inconvenient without tooling.", "Many modules can mean many requests.", "Still plain JavaScript rather than TypeScript or JSX."],
    browser: "Yes", build: "None", publish: "The module tree"
  },
  {
    n: "04", group: "build", accent: "#e9c46a", kind: "Compile", title: "HTML + CSS + TypeScript", file: "index.html + styles.css + main.ts",
    summary: "You author .ts, but the browser receives compiled .js. TypeScript is never the final web payload.",
    use: "DOM-heavy tools where type safety helps but React would add unnecessary runtime and project complexity.",
    tree: "site/\n├── index.html\n├── package.json\n├── tsconfig.json\n└── src/\n    ├── main.ts\n    └── styles.css\n\ndist/  ← publish this",
    requirements: ["package.json declares TypeScript/build dependencies and scripts.", "tsconfig.json defines type-checking and output assumptions.", "A compiler or bundler creates browser-ready JavaScript. Vite is a common small-project choice."],
    pros: ["Type safety without a UI framework.", "Safer refactoring and clearer data shapes.", "A bundler can hash and optimize assets."],
    cons: ["Node/npm and a build step become required.", "Source cannot be uploaded as-is.", "Types disappear at runtime."],
    browser: "No", build: "Required", publish: "Compiled HTML/CSS/JS"
  },
  {
    n: "05", group: "build", accent: "#d0bcff", kind: "Transform", title: "One JSX source file", file: "main.jsx",
    summary: "One JSX file can contain an entire React UI and its mount call, but it still needs an HTML root, React, and JSX transformation supplied somewhere.",
    use: "Sandboxes, embedded demos, and tiny React apps where a platform or build system supplies the surrounding project.",
    tree: "site/\n├── index.html       # <div id=\"root\">\n├── package.json     # React + build tool\n└── src/\n    └── main.jsx     # App + createRoot\n\ndist/              # publish this",
    requirements: ["An HTML document with a mount element.", "React and React DOM dependencies.", "A transform/build step; conventional browsers do not parse raw JSX."],
    pros: ["Concise component-oriented authoring.", "Easy to paste into React-enabled environments.", "A tiny app can live in one editable source file."],
    cons: ["Not browser-native syntax.", "The one-file experience often hides fixtures.", "A giant component becomes hard to maintain quickly."],
    browser: "No", build: "Required", publish: "Transformed bundle"
  },
  {
    n: "06", group: "build", accent: "#9bc7ff", kind: "Component source", title: "One App.tsx", file: "App.tsx",
    summary: "App.tsx is conventionally the main typed React component—not a complete document, dependency manifest, mount entry, or production build.",
    use: "A small typed React interface inside an existing React/Vite/framework project, or a platform that explicitly treats App.tsx as the entry.",
    tree: "site/\n├── index.html\n├── package.json\n├── tsconfig.json\n├── vite.config.ts\n└── src/\n    ├── main.tsx     # mounts React\n    ├── App.tsx      # primary component\n    └── styles.css   # optional\n\ndist/              # publish this",
    requirements: ["index.html supplies the document and root element.", "main.tsx imports App and mounts React DOM.", "package.json, tsconfig, and usually framework/build configuration supply dependencies and TSX transformation."],
    pros: ["Typed props, state, and editor feedback.", "Natural growth into reusable components.", "Mature tooling and ecosystem."],
    cons: ["Much more machinery than static HTML.", "Client runtime cost may be unjustified for content pages.", "Calling it a one-file site hides the actual fixtures."],
    browser: "No", build: "Required", publish: "Built app assets"
  },
  {
    n: "07", group: "build", accent: "#f2b8d2", kind: "Generate", title: "One .astro page", file: "index.astro",
    summary: "Inside an Astro project, one page can hold markup, scoped styles, build-time logic, and browser scripts, then generate static HTML.",
    use: "Explainers, docs, content-heavy microsites, and mostly-static pages that need selective interactivity.",
    tree: "site/\n├── package.json\n├── astro.config.mjs  # often optional\n└── src/pages/\n    └── index.astro\n\ndist/               # generated site",
    requirements: ["An Astro project and Node build environment.", "The page lives under src/pages to become a route.", "The host receives generated HTML/CSS/JS, not the .astro source."],
    pros: ["Excellent static output with little client JS.", "Expressive one-file page authoring.", "Can hydrate React only where needed."],
    cons: ["Still requires a framework build.", "Overkill for the tiniest page.", "Server behavior requires an adapter/runtime."],
    browser: "No", build: "Required", publish: "Generated static files"
  },
  {
    n: "08", group: "runtime", accent: "#f2b8b5", kind: "Runtime", title: "One Worker or server function", file: "src/index.ts",
    summary: "A request handler returns an HTML response directly. There may be no index.html source because runtime code creates the document.",
    use: "Tiny dynamic pages, request-aware output, redirects, auth gates, API-plus-HTML prototypes, and edge experiments.",
    tree: "site/\n├── package.json\n├── platform-config.jsonc\n└── src/index.ts\n\n# Dashboard editors may hide fixtures.",
    requirements: ["A platform runtime that invokes the handler.", "A response body containing HTML with Content-Type: text/html.", "Deployment configuration or a dashboard that supplies it."],
    pros: ["Dynamic output without an always-on server.", "Can use headers, cookies, URL data, and secrets.", "One handler can serve HTML and APIs."],
    cons: ["More operational failure modes than static files.", "Platform/runtime configuration is mandatory.", "Generating static content on every request can be wasteful."],
    browser: "Receives output", build: "Platform-dependent", publish: "Runtime code"
  },
  {
    n: "09", group: "native", accent: "#8bd9a5", kind: "Deployment artifact", title: "A generated dist folder", file: "dist/",
    summary: "Static hosting does not care whether the source was React, TypeScript, or Astro. It cares that the output contains browser-ready files.",
    use: "Publishing any build-based static site to a host that accepts drag-and-drop or prebuilt output.",
    tree: "dist/\n├── index.html\n├── assets/\n│   ├── index-a1b2c3.js\n│   └── index-d4e5f6.css\n└── other-route/index.html",
    requirements: ["Run the source project build first.", "Upload the configured output folder—not src/App.tsx.", "For client-side routers, configure deep-link rewrites when needed."],
    pros: ["Portable across static hosts.", "No production Node process for static output.", "CDN-friendly files and hashed assets."],
    cons: ["Must rebuild after source changes.", "Generated files should not be the canonical source.", "Host routing rules may still be needed."],
    browser: "Yes", build: "Already completed", publish: "The folder itself"
  }
];

const rows = approaches.map(({title, browser, build, publish, use}) => ({title, browser, build, publish, use}));
---
<!doctype html>
