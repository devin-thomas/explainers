<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#0b0b12" />
  <meta name="description" content="A detailed guide to the smallest practical website structures: one HTML file, CSS and JavaScript splits, TypeScript, JSX, App.tsx, Astro, Workers, and dist folders." />
  <meta name="application-name" content="Explainers" />
  <meta name="apple-mobile-web-app-title" content="Explainers" />
  <meta property="og:site_name" content="Explainers" />
