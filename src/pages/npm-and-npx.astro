---
import NpmNpxExplainer from "../components/NpmNpxExplainerEntry";
import ExplainerPageIntro from "../components/ExplainerPageIntro.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0d0d12" />
    <meta
      name="description"
      content="A beginner-focused interactive guide to npm, npx, package.json, package-lock.json, node_modules, project scripts, and common package commands."
    />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Explainers" />
    <meta property="og:title" content="npm & npx" />
    <meta property="og:description" content="Learn when to use npm, when to use npx, and what the files in a Node project actually do." />
    <meta property="og:url" content="https://explainers.uppercut-labs.workers.dev/npm-and-npx" />
    <meta property="og:image" content="https://explainers.uppercut-labs.workers.dev/icons/app-icon-512.png" />
    <title>npm & npx — Explainers</title>
    <meta name="application-name" content="Uppercut Labs Explainers" />
    <meta name="apple-mobile-web-app-title" content="Explainers" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="mobile-web-app-capable" content="yes" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="icon" href="/icons/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <script is:inline src="/pwa.js" defer></script>
    <style>html, body { min-height: 100%; margin: 0; background: #0d0d12; }</style>
  </head>
  <body class="explainer-page-with-intro">
    <ExplainerPageIntro
      title="npm & npx"
      hook="Memory aid: npm is commonly read as Node Package Manager; npx is the package executor—think Node Package Execution. npm manages the toolbox, while npx runs a tool from it."
    />
    <NpmNpxExplainer client:load />
  </body>
</html>
