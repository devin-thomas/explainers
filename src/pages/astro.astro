---
import AstroExplainer from "../components/AstroExplainer";
import ExplainerPageIntro from "../components/ExplainerPageIntro.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0b0d12" />
    <meta
      name="description"
      content="An interactive Uppercut Labs explainer showing how Astro relates to React, Vite, GitHub, and Cloudflare Workers."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>What is Astro? — Explainers</title>
    <meta property="og:title" content="What is Astro?" />
    <meta name="application-name" content="Uppercut Labs Explainers" />
    <meta name="apple-mobile-web-app-title" content="Explainers" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="mobile-web-app-capable" content="yes" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="icon" href="/icons/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <script is:inline src="/pwa.js" defer></script>
    <style>html, body { min-height: 100%; margin: 0; background: #0a0d13; }</style>
  </head>
  <body class="explainer-page-with-intro">
    <ExplainerPageIntro
      title="What is Astro?"
      hook="How Astro, React, Vite, GitHub, and Cloudflare Workers divide the work of building and publishing this explainer collection."
    />
    <AstroExplainer client:load />
  </body>
</html>
